APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-please-use-a-strong-random-secret

DATABASE_URL=postgresql+asyncpg://ghostmon:ghostmon@localhost:5432/ghostmon

JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60

OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/oidc/callback

# SMTP for email notifications. Leave SMTP_HOST empty to disable email channel delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=ghostmonitor@localhost
SMTP_STARTTLS=true

# Public-facing base URL used in notification bodies (links back to the monitor).
PUBLIC_BASE_URL=http://localhost:8000

# Metric history retention in days; samples and probe results older than this are
# pruned hourly. Set to 0 to keep everything.
HISTORY_RETENTION_DAYS=30
